datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

//
// USUARIO: base de todo el flujo
//
model User {
  id        Int       @id @default(autoincrement())
  name      String?
  email     String    @unique
  role      String    @default("Candidato") // ← NECESARIO PARA TU API

  // Datos personales extendidos
  state     String?
  city      String?
  zone      String?
  address   String?
  phone     String?

  // Relaciones
  candidate   Candidate?
  experiences Experience[]
  educations  Education[]
  documents   Document[]
}

//
// CANDIDATO: estado y progreso dentro del proceso
//
model Candidate {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  status    String     @default("Pendiente")
  progress  Int        @default(0)

  user        User        @relation(fields: [userId], references: [id])
  preferences JobPreference?
  availability Availability?
}

//
// EXPERIENCIA LABORAL
//
model Experience {
  id          Int      @id @default(autoincrement())
  userId      Int
  position    String
  company     String
  startDate   DateTime?
  endDate     DateTime?
  description String?

  user        User     @relation(fields: [userId], references: [id])
}

//
// EDUCACIÓN / FORMACIÓN
//
model Education {
  id          Int      @id @default(autoincrement())
  userId      Int
  school      String
  degree      String
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  description String?

  user        User     @relation(fields: [userId], references: [id])
}

//
// PREFERENCIAS LABORALES
//
model JobPreference {
  id              Int      @id @default(autoincrement())
  candidateId     Int      @unique

  desiredRole       String?
  desiredSalary     Int?
  workMode          String?   // Presencial / Híbrido / Remoto
  travelAvailability Boolean   @default(false)

  candidate        Candidate @relation(fields: [candidateId], references: [id])
}

//
// DISPONIBILIDAD
//
model Availability {
  id          Int      @id @default(autoincrement())
  candidateId Int      @unique

  fullTime    Boolean  @default(false)
  partTime    Boolean  @default(false)
  weekends    Boolean  @default(false)
  immediate   Boolean  @default(true)

  candidate    Candidate @relation(fields: [candidateId], references: [id])
}

//
// DOCUMENTOS
//
model Document {
  id         Int      @id @default(autoincrement())
  userId     Int
  type       String   // CV, INE, Comprobante, etc.
  url        String   // Ruta del archivo
  uploadedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}
