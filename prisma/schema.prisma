generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

model User {
  id        Int       @id @default(autoincrement())
  name      String?
  email     String    @unique
  password  String?
  role      UserRole  @default(CANDIDATE)
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  candidate    Candidate?
  recruiter    Recruiter?
  applications Application[]
}

model Candidate {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  user   User @relation(fields: [userId], references: [id])
  userId Int  @unique

  preferences String?
  status      String?

  skills     String[]
  headline   String?
  summary    String?
  experience Json?
  education  Json?

  documents Document[]

  // Nuevos modelos del registro
  personal     CandidatePersonal?
  expSection   CandidateExperience?
  eduSection   CandidateEducation?
  prefSection  CandidatePreferences?
  availSection CandidateAvailability?
  docsSection  CandidateDocuments?
}

model CandidatePersonal {
  id       Int     @id @default(autoincrement())
  userId   Int     @unique

  name     String?
  email    String?
  state    String?
  city     String?
  zone     String?
  address  String?
  phone    String?

  candidate Candidate @relation(fields: [userId], references: [userId])
}

model CandidateExperience {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique

  company   String?
  position  String?
  years     Int?
  description String?

  candidate Candidate @relation(fields: [userId], references: [userId])
}

model CandidateEducation {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique

  school    String?
  degree    String?
  graduationYear Int?

  candidate Candidate @relation(fields: [userId], references: [userId])
}

model CandidatePreferences {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique

  area      String?
  salary    Int?
  modality  String?

  candidate Candidate @relation(fields: [userId], references: [userId])
}

model CandidateAvailability {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique

  schedule  String?
  travel    Boolean?
  relocate  Boolean?

  candidate Candidate @relation(fields: [userId], references: [userId])
}

model CandidateDocuments {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique

  cvUrl     String?
  ineUrl    String?
  proofUrl  String?

  candidate Candidate @relation(fields: [userId], references: [userId])
}

model Recruiter {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation(fields: [userId], references: [id])
  userId Int  @unique

  position  String?
  phone     String?
  companyId Int?

  vacancies Vacancy[]
}

model Document {
  id        Int      @id @default(autoincrement())
  url       String
  type      String
  createdAt DateTime @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id])
  candidateId Int
}

model Vacancy {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  location    String?
  type        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?

  recruiter   Recruiter? @relation(fields: [recruiterId], references: [id])
  recruiterId Int?

  applications Application[]
}

model Application {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  status ApplicationStatus @default(PENDING)

  user   User @relation(fields: [userId], references: [id])
  userId Int

  vacancy   Vacancy @relation(fields: [vacancyId], references: [id])
  vacancyId Int
}
